{
  "name": "cursor-curator",
  "version": "4.0.0",
  "description": "Git-installable Cursor Curator — objective orchestration for Cursor (upstream Cursor Curator 0.3.8)",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@latest",
  "scripts": {
    "build": "tsc -p cursor-curator/tsconfig.json && bun cursor-curator/scripts/copy-board-fragments.mjs",
    "test:dev": "bun test cursor-curator/src",
    "check": "bun scripts/check-port.mjs",
    "install:cursor": "bun scripts/install-from-repo.mjs"
  },
  "bin": {
    "curator": "./cursor-curator/dist/cli/curator.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.1",
    "zod": "^3.25 || ^4.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "bun-types": "latest"
  }
}
