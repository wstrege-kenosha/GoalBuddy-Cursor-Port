{
  "name": "cursor-curator",
  "version": "4.0.0",
  "description": "Git-installable Cursor Curator — objective orchestration for Cursor (upstream Cursor Curator 0.3.8)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p cursor-curator/tsconfig.json",
    "test:dev": "tsx --test cursor-curator/src/**/*.test.mts",
    "check": "node scripts/check-port.mjs",
    "install:cursor": "node scripts/install-from-repo.mjs"
  },
  "bin": {
    "curator": "./cursor-curator/dist/cli/curator.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.1",
    "zod": "^3.25 || ^4.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
