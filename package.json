{
  "name": "goalbuddy-cursor-port",
  "version": "2.0.0",
  "description": "Git-installable Cursor port of GoalBuddy (upstream 0.3.8)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @goalbuddy/runner",
    "check": "npm run build && node scripts/check-port.mjs",
    "install:cursor": "node scripts/install-from-repo.mjs"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.19",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
